      "Bash(pkill -:*)",
      "Bash(nc -l -:*)",
      "Bash(ncat -l -:*)",
      "Bash(netcat -l -:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(rm -rf ~/.ssh*)",
      "Bash(rm -rf ~/.config*)"
